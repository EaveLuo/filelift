completion-path-directory = 目录
completion-path-file = 文件
completion-upload-more-paths = 继续添加文件 · 输入 -- 选择选项 · 回车上传
completion-panel-multiselect-hint = 已选 { $count } 个 · 空格勾选 · 回车上传
completion-hint-prefix = 提示：{ $suggestions }
completion-hint-decorated = { $hint }  ·  Tab 补全 / 查看更多

prompt-bucket = 存储桶
prompt-provider = 提供商
prompt-endpoint = 端点
prompt-region = 区域
prompt-public-base-url = 公开访问基础 URL
prompt-folder = 基础文件夹（会拼接到每次上传路径的最前面；支持 yyyy/MM/dd/date 占位符）
prompt-access-key-id = Access key ID
prompt-secret-access-key = Secret access key
prompt-save-access-keys-now = 现在保存访问密钥吗？[Y/n]: 
prompt-please-answer-yes-no = 请输入 y 或 n。
prompt-cannot-be-empty = { $label } 不能为空。

target-added = 已添加 target `{ $name }`。
target-updated = 已更新 target `{ $name }`。
target-using = 正在使用 target `{ $name }`。
target-removed = 已移除 target `{ $name }`。
target-draft-resuming = 正在继续 draft target `{ $name }`。
target-draft-saved = 已保存 draft target `{ $name }`；再次运行 `filelift target add { $name }` 即可继续。
target-no-targets-configured = 还没有配置 target。
target-checking-connectivity = 正在检查 target 连通性...
target-connectivity-passed = Target 连通性检查通过。
target-connectivity-skipped-no-credentials = 未保存访问密钥，已跳过 target 连通性检查。

language-current = 当前语言：{ $language }

log-exported = 已导出诊断日志到 { $path }（{ $count } 条事件）。分享前请先检查内容。
log-cleared = 已清空诊断日志。

upload-missing-credentials = target `{ $target }` 缺少访问凭证；请运行 `filelift target update { $target }` 保存访问密钥。
upload-name-single-file-only = --name 只能用于单个文件输入。
upload-path-not-found = 以下上传路径不存在：{ $paths }。
upload-renamed-on-conflict = 为避免 key 冲突已重命名：{ $local } -> { $key }。

credentials-export-missing = target `{ $target }` 没有已保存的凭证；请运行 `filelift target add { $target }` 或设置 FILELIFT_* 环境变量。
credentials-export-warning = 已将 `{ $target }` 的凭证以明文环境变量形式导出。请谨慎处理，给 agent 使用时优先采用作用域受限、可吊销的密钥。
non-interactive-missing-fields = 非交互模式需要以下选项：{ $fields }。
non-interactive-partial-credentials = 非交互模式下请同时提供 access key id 和 secret access key。

update-available = filelift 有新版本可用：{ $current } -> { $latest }。运行 `{ $command }` 进行更新。
upgrade-starting = 正在将 filelift 更新到最新版本……
upgrade-succeeded = filelift 更新成功。
upgrade-failed = 安装脚本执行出错，filelift 未更新。
upgrade-spawn-failed = 无法运行安装脚本（`{ $program }`），请确认它可用。
upgrade-unsupported-os = 当前平台（{ $os }）不支持自动更新，请按 README 说明重新安装。
upgrade-via-cargo = 检测到通过 cargo 安装，正在使用 `cargo install` 升级……
upgrade-cargo-manual = filelift 是用 cargo 安装的。请在新终端中运行 `{ $command }` 进行升级（Windows 下正在运行的二进制无法自我替换）。
