completion-opt-secret-access-key = secret access key
completion-opt-set-default = 设为默认 target
completion-opt-skip-check = 跳过连通性检查
completion-opt-target = target 名称
completion-opt-name = 对象 key 名称
completion-opt-ignore-target-folder = 跳过 target 的基础文件夹
